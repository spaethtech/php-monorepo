{
    "name": "spaethtech/php-monorepo",
    "description": "The mono repo for all of our PHP libraries.",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "composer/composer": "^2.5",
        "symfony/console": "^5.4",
        "consolidation/robo": "^4.0",
        "spaethtech/robo": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^9"
    },
    "autoload": {
        "files": [
            "globals.php"
        ],
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "lib/*",
            "options": {
                "symlink": true
            }
        }
    ]
}
